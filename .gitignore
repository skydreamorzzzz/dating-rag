.env
.venv/
.claude/
__pycache__/
*.pyc
.pytest_cache/

# Private/source documents and generated datasets
data/raw/*
data/interim/*
data/processed/*
data/chunks/*
data/vector_store/*
storage/*

# Keep directory placeholders if present
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/success/
data/processed/success/*
!data/processed/success/.gitkeep
!data/processed/failed/
data/processed/failed/*
!data/processed/failed/.gitkeep
!data/chunks/.gitkeep
!data/vector_store/.gitkeep
!storage/.gitkeep

# Samples/examples are allowed in git
!data/samples/
!data/samples/**
